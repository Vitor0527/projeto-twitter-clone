PORT=3001
NODE_ENV=development

# MySQL local
DB_HOST=localhost
DB_USER=projeto_user
DB_PASSWORD=sua_senha_forte
DB_NAME=twitter_projeto
DB_PORT=3306
DB_DIALECT=mysql

# Aiven / produção (recomendado — local e Render)
# DATABASE_URL=mysql://avnadmin:PASSWORD@HOST:PORT/defaultdb
# DB_SSL=true
# DB_SSL_MODE=REQUIRED
# DB_SSL_CA_PATH=./ca.pem
# No Render (sem ca.pem no repo): use DB_SSL_CA em base64 ou DB_REJECT_UNAUTHORIZED=false

JWT_SECRET=altere_esta_chave_em_producao
JWT_EXPIRATION=24h

# Conta administrador (criada/atualizada no arranque do servidor)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@vg.local

MAX_FILE_SIZE=5242880
UPLOAD_FOLDER=./uploads
