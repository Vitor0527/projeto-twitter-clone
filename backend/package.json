{
  "name": "projeto-backend",
  "version": "1.0.0",
  "description": "Backend API for Twitter-like application",
  "main": "app.js",
  "scripts": {
    "postinstall": "node scripts/render-build-frontend.js",
    "build:frontend": "npm install --prefix ../frontend && npm run build --prefix ../frontend",
    "render-build": "npm run build:frontend && npm install",
    "start": "node ./bin/www",
    "dev": "nodemon ./bin/www",
    "swagger": "node swagger.js",
    "db:init": "node scripts/ensure-database.js && node scripts/reset-database.js",
    "db:reset": "node scripts/reset-database.js",
    "db:create": "node scripts/ensure-database.js",
    "db:migrate": "node scripts/migrate-media-columns.js",
    "db:retweets": "node scripts/sync-retweets-table.js",
    "db:admin": "node -e \"require('dotenv').config(); const {sequelize}=require('./config/database'); require('./models'); const {ensureDefaultAdmin}=require('./scripts/ensure-admin'); sequelize.authenticate().then(()=>ensureDefaultAdmin()).then(()=>process.exit(0)).catch(e=>{console.error(e);process.exit(1)});\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "debug": "^4.3.4",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.2.0",
    "pg": "^8.16.3",
    "sequelize": "^6.31.1",
    "sequelize-cli": "^6.6.1",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^2.0.20"
  }
}
