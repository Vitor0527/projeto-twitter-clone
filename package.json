{
  "name": "projeto-front-back",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "postinstall": "npm install --prefix backend",
    "render-build": "npm run render-build --prefix backend",
    "setup": "npm install --prefix backend && npm install --prefix frontend",
    "predev": "npx --yes kill-port 3001",
    "dev": "concurrently -k \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "build": "npm run build --prefix frontend",
    "preview": "npm run preview --prefix frontend",
    "start": "npm run start --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
